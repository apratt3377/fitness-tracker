@startuml
hide footbox
title Workout Deletion Flow

' Tier 1: External & Entry
actor "User (React App)" as C 
participant "API Gateway" as APIG <<Infrastructure>>

' Tier 2: Core Domain
participant "Workout Management Service" as WS <<Service>>
database "Workout DB" as WDB <<Database>>

' Tier 3: Async Infrastructure
participant "Workout.Domain.Events (SNS)" as WTSNS
queue "Cleanup Queue (SQS)" as CQ

' Tier 4: Downstream Consumers
participant "Notification Service" as NS <<Service>>
participant "Notification DB" as NDB <<Database>>

== Synchronous Request/Response ==

C -> APIG : DELETE /api/workouts/{id}
APIG -> WS : Forward Request

alt DB Success
    WS -> WDB : **Mark Inactive (Soft Delete)**
    
    WS -> WTSNS : Emit 'WorkoutDeleted' {action: "delete"}
    
    WS --> APIG : 200 OK
    APIG --> C : Success
else DB Failure
    WS --> APIG : 500 Error
    APIG --> C : Error
end

== Async Processing ==

WTSNS -> CQ : Filter match: action == "delete"

NS -> CQ : Consume 'WorkoutDeleted' Event

alt Cleanup Success
    NS -> NDB : Mark Notifications as Archived
    note right: Ensures data consistency for UI
else Cleanup Failure
    CQ -> CQ : [Internal] Move to Cleanup-DLQ
end

@enduml