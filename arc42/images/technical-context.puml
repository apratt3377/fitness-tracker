@startuml
skinparam componentStyle uml2

header Technical Context

node "Client Device" as client {
    component "fitnessTracker::web" as web <<SPA>>
}

node "Local Server" as host {
    package "fitnessTracker System" {
        component "fitnessTracker::api" as api
    }
}

' Specific Gemini Cloud
cloud "Google AI (Gemini)" as gemini <<external>> #White {
    component "Gemini 1.5 Flash" as model #LightGray
}

' Technical Connections
web -- api : "HTTP / JSON"
api -- model : "HTTPS\n(API Key Auth)"

@enduml